<script type="application/x-cpp-head">
    #include <cmath>
    double square(double x) { return x * x; }
</script>

<div>
    <h1>User Profile</h1>
    <script type="application/x-cpp-source">
        auto age = context.user.getAge();
    </script>
    <p>Age squared: {{square(age)}}</p>
    
    <script type="application/x-cpp-head">
        #include <vector>
        using Numbers = std::vector<int>;
    </script>
    
    <script type="application/x-cpp-source">
        Numbers scores = context.user.getScores();
    </script>
    
    <ul>
        <li cpp-for="const auto& score : scores">Score: {{score}}</li>
    </ul>
    
    <script src="/js/app.js"></script>
</div>