<div class="profile">
    <h1 cpp-text="user.getName()">Default Name</h1>
    <div cpp-if="user.isActive()">
        <p>User is active</p>
        <ul>
            <li cpp-for="const auto& item : user.getItems()">
                <a cpp:href="item.url" cpp-text="item.title">Link Text</a>
            </li>
        </ul>
    </div>
    <div class="static">Static content here</div>
</div>