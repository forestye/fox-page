<!DOCTYPE html>
<html lang="en" data-theme="auto">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>fox-page demo</title>
    <link rel="stylesheet" href="/static/pico.min.css">
    <script type="application/x-cpp-head">
        #include "feature.h"
        #include <vector>
        #include <string>
    </script>
    <style>
        main.container { padding-top: 2rem; padding-bottom: 2rem; max-width: 48rem; }
        .pill { display: inline-block; padding: .15rem .55rem; border-radius: 999px;
                background: var(--pico-secondary-background); font-size: .8rem; }
        footer small { color: var(--pico-muted-color); }
    </style>
</head>
<body>
    <main class="container">
        <hgroup>
            <h1>Hello, {{name}}!</h1>
            <p>This page was rendered at <span class="pill">{{timestamp}}</span>
               via a single <code>writev</code>.</p>
        </hgroup>

        <article>
            <header><strong>Try a different name</strong></header>
            <p>
                <a href="/hello/fox" role="button" class="secondary">/hello/fox</a>
                <a href="/hello/yelin" role="button" class="secondary">/hello/yelin</a>
            </p>
            <footer><small>Each link refreshes the timestamp and re-renders the page.</small></footer>
        </article>

        <section cpp-if="!features.empty()">
            <h2>What this single page exercises</h2>
            <ul>
                <li cpp-for="const auto& f : features">
                    <strong cpp-text="f.title"></strong> &mdash;
                    <span cpp-text="f.note"></span>
                </li>
            </ul>
        </section>

        <section cpp-if="features.empty()">
            <p><em>No features configured.</em></p>
        </section>

        <footer>
            <hr>
            <small>
                Source: <code>example/home.htpl</code>.
                Generated by
                <a href="https://github.com/forestye/fox-page">fox-page</a>,
                served by
                <a href="https://github.com/forestye/fox-http">fox-http</a>.
            </small>
        </footer>
    </main>
</body>
</html>
